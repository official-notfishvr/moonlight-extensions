{
  "name": "noPendingCount",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "dev:server": "pnpm run build && pnpm run repo-ser:build && concurrently -k -n build,repo-ser \"pnpm run dev\" \"pnpm run repo-ser:serve\"",
    "clean": "node build.mjs --clean",
    "repo": "node repo.mjs",
    "repo:build": "node repo.mjs",
    "repo-ser": "node repo-ser.mjs",
    "repo-ser:build": "node repo-ser.mjs",
    "repo-ser:serve": "node server.mjs",
    "repo:serve": "node server.mjs",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint:report": "eslint --output-file eslint_report.json --format json src",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run typecheck"
  },
  "devDependencies": {
    "@electron/asar": "^3.2.8",
    "@moonlight-mod/esbuild-config": "^1.0.0",
    "@moonlight-mod/eslint-config": "github:moonlight-mod/eslint-config",
    "concurrently": "^9.2.1",
    "esbuild": "^0.19.3",
    "eslint": "^9.12.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "@moonlight-mod/mappings": "^2026.4.0",
    "@moonlight-mod/types": "^2026.4.0"
  }
}
